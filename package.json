{
  "name": "caravel-ai",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "caravel": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev:web": "bun --watch src/index.ts start --web --replace-existing",
    "telegram": "bun run src/index.ts telegram",
    "discord": "bun run src/index.ts discord",
    "status": "bun run src/index.ts status",
    "build:island": "vite build",
    "dev:island": "vite build --watch"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@vitejs/plugin-vue": "^5",
    "vite": "^6"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.3",
    "ogg-opus-decoder": "^1.7.3",
    "pinia": "^3",
    "vue": "^3"
  }
}
