#!/usr/bin/env bash
# caravel — start, stop, or restart the Caravel multi-agent daemon.
#
# Usage:
#   bash scripts/caravel start       # start (or restart) the daemon
#   bash scripts/caravel stop        # stop the daemon
#   bash scripts/caravel --foreground  # start attached, streaming logs
#   bash scripts/caravel --help
#
# Standalone-friendly: when run from within the cloned repo
# (e.g. `bash scripts/caravel start` after `cd caravel`),
# CARAVEL_PROJECT_DIR and CARAVEL_REPO_DIR default to the repo root.
# For consuming projects, pass CARAVEL_PROJECT_DIR explicitly or via a thin
# caller script — the same env vars supported by scripts/restart-claw.sh apply.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

export CARAVEL_PROJECT_DIR="${CARAVEL_PROJECT_DIR:-$REPO_ROOT}"
export CARAVEL_REPO_DIR="${CARAVEL_REPO_DIR:-$REPO_ROOT}"

ARGS=()
for arg in "$@"; do
  case "$arg" in
    start) ;;             # default behaviour — no-op flag
    stop) ARGS+=("--stop-only") ;;
    *) ARGS+=("$arg") ;;
  esac
done

exec "$SCRIPT_DIR/restart-caravel.sh" "${ARGS[@]}"
